<odoo>

    <record id="fastapi_log_action_from_endpoint" model="ir.actions.act_window">
        <field name="name">Fastapi Log</field>
        <field name="res_model">api.log</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('fastapi_endpoint_id', '=', active_id)]</field>
        <field name="context">{'default_fastapi_endpoint_id': active_id}</field>
    </record>


    <record id="fastapi_endpoint_form_view" model="ir.ui.view">
        <field name="model">fastapi.endpoint</field>
        <field name="inherit_id" ref="fastapi.fastapi_endpoint_form_view" />
        <field name="arch" type="xml">

            <div class="oe_button_box" name="button_box" position="inside">
                <button
                    type="action"
                    name="%(fastapi_log.fastapi_log_action_from_endpoint)s"
                    icon="fa-book"
                    groups="api_log.group_api_log"
                    attrs="{'invisible': [('fastapi_log_count', '=', 0)]}"
                >
                    <field string="Logs" name="fastapi_log_count" widget="statinfo" />
                </button>
            </div>


            <field name="save_http_session" position="after">
                <field name="log_requests" groups="api_log.group_api_log" />
            </field>
        </field>
    </record>

</odoo>
