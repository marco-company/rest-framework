<odoo>
    <record id="fastapi_log_action" model="ir.actions.act_window">
        <field name="name">Fastapi Logs</field>
        <field name="res_model">api.log</field>
        <field name="domain">[
            ("collection_model", "=", "fastapi.endpoint"),
        ]</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_fastapi_log"
        name="Fastapi Logs"
        sequence="100"
        parent="fastapi.menu_fastapi_root"
        action="fastapi_log_action"
    />
</odoo>
